// Only sync content, assets, and Obsidian config
// Everything else is managed by git
/**
!src/content/**
!src/assets/**
!.obsidian/**

// Exclude per-machine Obsidian workspace layout
.obsidian/workspace.json
.obsidian/workspace-mobile.json

// Exclude plugin/theme binaries (downloaded per machine)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/themes/*/theme.css

// Exclude local caches
.obsidian/graph.json
.obsidian/recovery/
