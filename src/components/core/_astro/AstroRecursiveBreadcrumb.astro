---
import {
  Breadcrumb,
  BreadcrumbList,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbSeparator,
  BreadcrumbPage,
} from "../breadcrumb";
import type { TranslateLabel } from "@i18n/labels";

type Props = {
  slug?: string;
  baseUrl: string;
  baseLabels: Record<string, string>;
  translateLabel: TranslateLabel;
};

const { baseUrl, baseLabels, slug, translateLabel } = Astro.props;
const fallbackLabel = baseLabels["en"] ?? "Home";
const segments = slug ? slug.split("/") : [];
---

<Breadcrumb>
  <BreadcrumbList>
    <BreadcrumbItem>
      <BreadcrumbLink href={baseUrl} data-locales={JSON.stringify(baseLabels)}>
        {fallbackLabel}
      </BreadcrumbLink>
    </BreadcrumbItem>

    {
      segments.map((segment, index) => {
        const isLast = index === segments.length - 1;
        const path = segments.slice(0, index + 1).join("/");
        const labels = translateLabel(segment);

        return (
          <>
            <BreadcrumbSeparator />
            <BreadcrumbItem>
              {isLast ? (
                <BreadcrumbPage data-locales={JSON.stringify(labels)}>
                  {labels.en}
                </BreadcrumbPage>
              ) : (
                <BreadcrumbLink
                  href={`${baseUrl}${path}/`}
                  data-locales={JSON.stringify(labels)}
                >
                  {labels.en}
                </BreadcrumbLink>
              )}
            </BreadcrumbItem>
          </>
        );
      })
    }
  </BreadcrumbList>
</Breadcrumb>
