---
import { getChildUrl } from "@lib/url";
import { Badge } from "../badge";
import type { TranslateLabel } from "@i18n/labels";

type Props = {
  childFolders: string[];
  baseUrl: string;
  translateLabel: TranslateLabel;
};

const { childFolders, baseUrl, translateLabel } = Astro.props;

const childUrl = (child: string) => getChildUrl(baseUrl, child);
---

{
  childFolders.length > 0 && (
    <nav aria-label="Sub-folders" class="flex flex-wrap gap-2">
      {childFolders.map((child) => {
        const labels = translateLabel(child);
        return (
          <a href={childUrl(child)}>
            <Badge variant="secondary" data-locales={JSON.stringify(labels)}>
              {labels.en}
            </Badge>
          </a>
        );
      })}
    </nav>
  )
}
