---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import AstroTagBadges from "@components/core/_astro/AstroTagBadges.astro";
import { Card } from "@components/core/card";
import type { TranslateLabel } from "@i18n/labels";

type Props = {
  entry: CollectionEntry<"art">;
  resolvedImage: string | ImageMetadata;
  translateLabel: TranslateLabel;
};

const { entry, resolvedImage, translateLabel } = Astro.props;
const { data } = entry;

const isImageMetadata = typeof resolvedImage !== "string";
---

<a
  href={`/${entry.collection}/${entry.id}/`}
  class="group focus-visible:ring-ring block focus-visible:ring-2 focus-visible:outline-none"
>
  <span class="sr-only">{data.title}</span>

  <Card className="relative aspect-square overflow-hidden p-0">
    <div class="bg-muted absolute inset-0 overflow-hidden">
      <div
        class="animate-shimmer via-foreground/[0.07] absolute inset-0 bg-gradient-to-r from-transparent to-transparent"
      >
      </div>
    </div>
    {
      isImageMetadata ? (
        <Image
          src={resolvedImage}
          alt={data.images[0]?.alt ?? data.title}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      ) : (
        <img
          src={resolvedImage}
          alt={data.images[0]?.alt ?? data.title}
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      )
    }

    <div
      class="absolute inset-0 flex flex-col justify-end bg-black/60 p-4 opacity-0 transition-opacity duration-300 group-focus-within:opacity-100 group-hover:opacity-100"
    >
      <h3 class="text-lg leading-tight font-medium text-white">
        {data.title}
      </h3>

      <div class="mt-2 flex flex-wrap gap-1.5">
        {
          (
            <AstroTagBadges
              tags={data.tags}
              translateLabel={translateLabel}
              className="h-auto border-white/30 bg-white/10 px-1.5 py-0.5 text-[10px] text-white"
            />
          )
        }
      </div>
    </div>
  </Card>
</a>
