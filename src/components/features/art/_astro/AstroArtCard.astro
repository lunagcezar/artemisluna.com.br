---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { Badge } from "@components/core/badge";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "@components/core/card";

type Props = {
  entry: CollectionEntry<"art">;
  resolvedImage: string | ImageMetadata;
};

const { entry, resolvedImage } = Astro.props;
const { data } = entry;

const imageSrc =
  typeof resolvedImage === "string" ? resolvedImage : resolvedImage.src;
---

<a
  href={`/${entry.collection}/${entry.id}/`}
  class="group block break-inside-avoid"
>
  <Card className="transition-shadow hover:shadow-md">
    <img
      src={imageSrc}
      alt={data.images[0]?.alt ?? data.title}
      loading="lazy"
      class="h-auto w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
    />

    <CardHeader>
      <CardTitle>{data.title}</CardTitle>
    </CardHeader>

    <CardContent>
      <div class="flex flex-wrap gap-1.5">
        <Badge variant="default">{data.type}</Badge>
        <Badge variant="secondary">{data.category}</Badge>
        <Badge variant="outline">{data.medium}</Badge>
        {data.series && <Badge variant="outline">{data.series}</Badge>}
        {data.tags.map((tag) => <Badge variant="ghost">{tag}</Badge>)}
      </div>
    </CardContent>
  </Card>
</a>
