---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import AstroArtCard from "./AstroArtCard.astro";
import { formatSegment } from "@lib/collections";
import { resolveArtImage } from "@lib/art";
import AstroPagination from "@components/core/_astro/AstroPagination.astro";
import AstroRecursiveBreadcrumb from "@components/core/_astro/AstroRecursiveBreadcrumb.astro";
import AstroRecursiveChildFolders from "@components/core/_astro/AstroRecursiveChildFolders.astro";

type Props = {
  collection: "art";
  entries: CollectionEntry<"art">[];
  slug?: string;
  childFolders: string[];
  page: number;
  totalPages: number;
  baseUrl: string;
};

const { collection, entries, slug, childFolders, page, totalPages, baseUrl } =
  Astro.props;

const segments = slug ? slug.split("/") : [];
const baseLabel = formatSegment(collection);
const rootUrl = `/${collection}/`;
const title = segments.length > 0 ? formatSegment(segments.at(-1)!) : baseLabel;

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/art/**/*.{jpg,jpeg,png,webp,gif}",
  { eager: true },
);
---

<div class="grid gap-6">
  <div class="grid gap-2">
    <AstroRecursiveBreadcrumb
      baseUrl={rootUrl}
      baseLabel={baseLabel}
      slug={slug}
    />

    <h1 class="text-3xl font-semibold tracking-tight">{title}</h1>
  </div>

  <AstroRecursiveChildFolders baseUrl={baseUrl} childFolders={childFolders} />

  <section
    aria-label="Artworks"
    class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      entries.map((entry) => {
        const firstImage = entry.data.images[0];
        const resolved = firstImage
          ? resolveArtImage(firstImage.src, imageModules)
          : "";

        return <AstroArtCard entry={entry} resolvedImage={resolved} />;
      })
    }
  </section>

  <AstroPagination
    baseUrl={baseUrl}
    currentPage={page}
    totalPages={totalPages}
  />
</div>
