---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import AstroArtCard from "./AstroArtCard.astro";
import { formatSegment } from "@lib/collections";
import { resolveArtImage } from "@lib/art";
import AstroPagination from "@components/core/_astro/AstroPagination.astro";
import AstroRecursiveBreadcrumb from "@components/core/_astro/AstroRecursiveBreadcrumb.astro";
import {
  createTranslateLabel,
  SUPPORTED_LOCALES,
  translations,
} from "@i18n/labels";

type Props = {
  collection: "art";
  entries: CollectionEntry<"art">[];
  slug?: string;
  page: number;
  totalPages: number;
  baseUrl: string;
};

const { collection, entries, slug, page, totalPages, baseUrl } = Astro.props;

const segments = slug ? slug.split("/") : [];
const baseLabel = formatSegment(collection);
const rootUrl = `/${collection}/`;
const lastSegment = segments.length > 0 ? segments.at(-1)! : undefined;
const title = lastSegment ? formatSegment(lastSegment) : baseLabel;
const translateLabel = createTranslateLabel();
const titleLabels = lastSegment ? translateLabel(lastSegment) : undefined;
const baseLabels = Object.fromEntries(
  SUPPORTED_LOCALES.map((locale) => [
    locale,
    translations[locale]?.[collection] ?? baseLabel,
  ]),
);

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/art/**/*.{jpg,jpeg,png,webp,gif}",
  { eager: true },
);
---

<div class="grid gap-6">
  <div class="grid gap-2">
    <AstroRecursiveBreadcrumb
      baseUrl={rootUrl}
      baseLabels={baseLabels}
      slug={slug}
      translateLabel={translateLabel}
    />

    <h1
      class="text-3xl font-semibold tracking-tight"
      data-locales={titleLabels
        ? JSON.stringify(titleLabels)
        : JSON.stringify(baseLabels)}
    >
      {title}
    </h1>
  </div>

  <section
    aria-label="Artworks"
    class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      entries.map((entry) => {
        const firstImage = entry.data.images[0];
        const resolved = firstImage
          ? resolveArtImage(firstImage.src, imageModules)
          : "";

        return (
          <AstroArtCard
            entry={entry}
            resolvedImage={resolved}
            translateLabel={translateLabel}
          />
        );
      })
    }
  </section>

  <AstroPagination
    baseUrl={baseUrl}
    currentPage={page}
    totalPages={totalPages}
  />
</div>
