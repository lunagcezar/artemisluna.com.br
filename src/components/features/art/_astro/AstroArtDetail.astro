---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import AstroRecursiveBreadcrumb from "@components/core/_astro/AstroRecursiveBreadcrumb.astro";
import AstroArticleImageViewer from "@components/shared/_astro/AstroArticleImageViewer.astro";
import AstroEntryMeta from "@components/core/_astro/AstroEntryMeta.astro";
import { ImageViewer } from "@components/shared/image-viewer";
import {
  createTranslateLabel,
  SUPPORTED_LOCALES,
  translations,
} from "@i18n/labels";

type Props = {
  entry: CollectionEntry<"art">;
  slug?: string;
};

const { entry, slug } = Astro.props;
const { data } = entry;
const translateLabel = createTranslateLabel();
const breadcrumbSlug = (slug ?? entry.id).split("/").slice(0, -1).join("/");
const baseLabels = Object.fromEntries(
  SUPPORTED_LOCALES.map((locale) => [
    locale,
    translations[locale]?.["art"] ?? "Art",
  ]),
);

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/art/**/*.{jpg,jpeg,png,webp,gif}",
  { eager: true },
);

function resolveImage(src: string): string | ImageMetadata {
  if (!src.startsWith("/src/assets/art/")) return src;
  const mod = imageModules[src] as { default: ImageMetadata } | undefined;
  return mod ? mod.default : src;
}

const resolvedImages = (data.images ?? []).map((img) => {
  const resolved = resolveImage(img.src);
  return {
    src: typeof resolved !== "string" ? resolved.src : resolved,
    alt: img.alt,
    caption: img.caption,
  };
});
---

<article class="grid gap-6">
  <div class="grid gap-2">
    <AstroRecursiveBreadcrumb
      baseUrl="/art/"
      baseLabels={baseLabels}
      slug={breadcrumbSlug}
      translateLabel={translateLabel}
      isDetail
    />

    <h1 class="text-3xl font-semibold tracking-tight">{data.title}</h1>

    <AstroEntryMeta entry={entry} translateLabel={translateLabel} />
  </div>

  <ImageViewer images={resolvedImages} client:load />

  <AstroArticleImageViewer entry={entry} />
</article>
