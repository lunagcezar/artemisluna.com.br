---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import AstroEntryContent from "@components/core/_astro/AstroEntryContent.astro";
import { Badge } from "@components/core/badge";
import { Card } from "@components/core/card";

type Props = {
  entry: CollectionEntry<"art">;
};

const { entry } = Astro.props;
const { data } = entry;

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/art/**/*.{jpg,jpeg,png,webp,gif}",
  { eager: true },
);

function resolveImage(src: string): string | ImageMetadata {
  if (!src.startsWith("/src/assets/art/")) return src;
  const mod = imageModules[src] as { default: ImageMetadata } | undefined;
  return mod ? mod.default : src;
}
---

<article class="grid gap-6">
  <div class="grid gap-2">
    <h1 class="text-3xl font-semibold tracking-tight">{data.title}</h1>

    <p class="text-muted-foreground text-sm">
      {data.date.toLocaleDateString("pt-BR")}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {data.tags.map((tag) => <Badge variant="ghost">{tag}</Badge>)}
    </div>
  </div>

  <div class="grid grid-cols-1 gap-2">
    {
      data.images?.map((img) => {
        const resolved = resolveImage(img.src);
        const isImageMetadata = typeof resolved !== "string";
        const href = isImageMetadata ? resolved.src : resolved;

        return (
          <a href={href}>
            <Card className="p-0">
              <figure class="break-inside-avoid overflow-hidden">
                {isImageMetadata && (
                  <Image src={resolved} alt={img.alt} class="h-auto w-full" />
                )}
                {img.caption && (
                  <figcaption class="text-muted-foreground p-3 text-sm">
                    {img.caption}
                  </figcaption>
                )}
              </figure>
            </Card>
          </a>
        );
      })
    }
  </div>

  <AstroEntryContent entry={entry} />
</article>
