---
export interface Props {
  currentPage: number;
  totalPages: number;
  prevUrl?: string;
  nextUrl?: string;
}

const { currentPage, totalPages, prevUrl, nextUrl } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="pagination">
      {prevUrl ? <a href={prevUrl}>← Anterior</a> : <span class="disabled">← Anterior</span>}

      <span class="info">
        Página {currentPage} de {totalPages}
      </span>

      {nextUrl ? <a href={nextUrl}>Próxima →</a> : <span class="disabled">Próxima →</span>}
    </nav>
  )
}

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1rem 0;
  }
  a {
    color: inherit;
    text-decoration: underline;
  }
  .disabled {
    opacity: 0.4;
    cursor: default;
  }
  .info {
    font-size: 0.875rem;
    opacity: 0.7;
  }
</style>
