---
export interface Props {
  currentPage: number;
  totalPages: number;
  prevUrl?: string;
  nextUrl?: string;
}

const { currentPage, totalPages, prevUrl, nextUrl } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="flex items-center justify-center gap-4 mt-8 py-4">
      {prevUrl ? (
        <a href={prevUrl} class="text-inherit underline">
          ← Anterior
        </a>
      ) : (
        <span class="opacity-40 cursor-default">← Anterior</span>
      )}

      <span class="text-sm opacity-70">
        Página {currentPage} de {totalPages}
      </span>

      {nextUrl ? (
        <a href={nextUrl} class="text-inherit underline">
          Próxima →
        </a>
      ) : (
        <span class="opacity-40 cursor-default">Próxima →</span>
      )}
    </nav>
  )
}
