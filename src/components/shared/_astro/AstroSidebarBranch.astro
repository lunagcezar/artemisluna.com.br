---
import { cn } from "@lib/utils";
import type { SidebarNode } from "@lib/collections";

type Props = {
  node: SidebarNode;
  getLabels: (node: SidebarNode) => Record<string, string>;
  isActive: (node: SidebarNode) => boolean;
  hasActiveDescendant: (node: SidebarNode) => boolean;
  depth?: number;
};

const {
  node,
  getLabels,
  isActive,
  hasActiveDescendant,
  depth = 0,
} = Astro.props;

const labels = getLabels(node);
const active = isActive(node);
const expanded = hasActiveDescendant(node);
const hasChildren = node.children.length > 0;
---

<li>
  <a
    href={node.href}
    data-locales={JSON.stringify(labels)}
    class={cn(
      "block rounded px-2 py-1 text-sm transition-colors hover:bg-accent hover:text-accent-foreground",
      active && "bg-accent font-medium text-accent-foreground",
    )}
  >
    {labels.en}
  </a>

  {
    hasChildren && expanded && (
      <ul class="border-border ml-3 border-l pl-3">
        {node.children.map((child) => (
          <Astro.self
            node={child}
            getLabels={getLabels}
            isActive={isActive}
            hasActiveDescendant={hasActiveDescendant}
            depth={depth + 1}
          />
        ))}
      </ul>
    )
  }
</li>
