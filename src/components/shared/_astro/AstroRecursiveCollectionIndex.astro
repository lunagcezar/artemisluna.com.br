---
import type { CollectionEntry, DataEntryMap } from "astro:content";
import AstroPagination from "@components/core/_astro/AstroPagination.astro";
import AstroRecursiveBreadcrumb from "@components/core/_astro/AstroRecursiveBreadcrumb.astro";
import AstroEntryList from "@components/core/_astro/AstroEntryList.astro";
import AstroArticleImageViewer from "@components/shared/_astro/AstroArticleImageViewer.astro";
import { formatSegment } from "@lib/collections";
import {
  createTranslateLabel,
  SUPPORTED_LOCALES,
  translations,
} from "@i18n/labels";

type Props = {
  collection: string;
  entries: CollectionEntry<keyof DataEntryMap>[];
  slug?: string;
  childFolders: string[];
  page: number;
  totalPages: number;
  baseUrl: string;
  baseLabel: string;
  indexEntry?: CollectionEntry<keyof DataEntryMap>;
};

const {
  collection,
  entries,
  slug,
  page,
  totalPages,
  baseUrl,
  baseLabel,
  indexEntry,
} = Astro.props;

const segments = slug ? slug.split("/") : [];
const lastSegment = segments.length > 0 ? segments.at(-1)! : undefined;
const title = lastSegment ? formatSegment(lastSegment) : baseLabel;
const rootUrl = `/${collection}/`;
const translateLabel = createTranslateLabel();
const titleLabels = lastSegment ? translateLabel(lastSegment) : undefined;
const baseLabels = Object.fromEntries(
  SUPPORTED_LOCALES.map((locale) => [
    locale,
    translations[locale]?.[collection] ?? baseLabel,
  ]),
);
---

<div class="grid gap-6">
  <div class="grid gap-2">
    <AstroRecursiveBreadcrumb
      baseUrl={rootUrl}
      baseLabels={baseLabels}
      slug={slug}
      translateLabel={translateLabel}
    />

    <h1
      class="text-3xl font-semibold tracking-tight"
      data-locales={titleLabels
        ? JSON.stringify(titleLabels)
        : JSON.stringify(baseLabels)}
    >
      {title}
    </h1>
  </div>

  {indexEntry && <AstroArticleImageViewer entry={indexEntry} />}

  <AstroEntryList
    collection={collection}
    entries={entries}
    translateLabel={translateLabel}
  />

  <AstroPagination
    baseUrl={baseUrl}
    currentPage={page}
    totalPages={totalPages}
  />
</div>
