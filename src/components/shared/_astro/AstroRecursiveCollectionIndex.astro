---
import type { CollectionEntry } from "astro:content";
import AstroPagination from "@components/core/_astro/AstroPagination.astro";
import AstroRecursiveBreadcrumb from "@components/core/_astro/AstroRecursiveBreadcrumb.astro";
import AstroArticleImageViewer from "@components/shared/_astro/AstroArticleImageViewer.astro";
import { formatSegment } from "@lib/collections";
import { createTranslateLabel } from "@i18n/labels";

type Props = {
  collection: "blog" | "wiki";
  entries: CollectionEntry<"blog" | "wiki">[];
  slug?: string;
  childFolders: string[];
  page: number;
  totalPages: number;
  baseUrl: string;
  baseLabel: string;
  indexEntry?: CollectionEntry<"blog" | "wiki">;
};

const {
  collection,
  entries,
  slug,
  page,
  totalPages,
  baseUrl,
  baseLabel,
  indexEntry,
} = Astro.props;

const segments = slug ? slug.split("/") : [];
const lastSegment = segments.length > 0 ? segments.at(-1)! : undefined;
const title = lastSegment ? formatSegment(lastSegment) : baseLabel;
const rootUrl = `/${collection}/`;
const translateLabel = createTranslateLabel(collection);
const titleLabels = lastSegment ? translateLabel(lastSegment) : undefined;
---

<div class="grid gap-6">
  <div class="grid gap-2">
    <AstroRecursiveBreadcrumb
      baseUrl={rootUrl}
      baseLabel={baseLabel}
      slug={slug}
      translateLabel={translateLabel}
    />

    <h1
      class="text-3xl font-semibold tracking-tight"
      data-locales={titleLabels ? JSON.stringify(titleLabels) : undefined}
    >
      {title}
    </h1>
  </div>

  {indexEntry && <AstroArticleImageViewer entry={indexEntry} />}

  <ul class="grid gap-4">
    {
      entries.map((entry) => (
        <li>
          <a
            href={`/${collection}/${entry.id}/`}
            class="border-border hover:bg-muted block rounded-lg border p-4 transition-colors"
          >
            <h2 class="font-medium">{entry.data.title}</h2>
            {entry.data.date && (
              <time class="text-muted-foreground text-sm">
                {entry.data.date.toLocaleDateString("pt-BR")}
              </time>
            )}
          </a>
        </li>
      ))
    }
  </ul>

  <AstroPagination
    baseUrl={baseUrl}
    currentPage={page}
    totalPages={totalPages}
  />
</div>
