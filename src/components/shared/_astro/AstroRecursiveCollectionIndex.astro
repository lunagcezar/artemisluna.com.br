---
import type { CollectionEntry, DataEntryMap } from "astro:content";
import AstroPagination from "@components/core/_astro/AstroPagination.astro";
import AstroRecursiveBreadcrumb from "@components/core/_astro/AstroRecursiveBreadcrumb.astro";
import AstroTagBadges from "@components/core/_astro/AstroTagBadges.astro";
import AstroArticleImageViewer from "@components/shared/_astro/AstroArticleImageViewer.astro";
import { formatSegment } from "@lib/collections";
import { formatDateForLocales } from "@lib/date";
import {
  createTranslateLabel,
  SUPPORTED_LOCALES,
  translations,
} from "@i18n/labels";
import {
  Item,
  ItemContent,
  ItemDescription,
  ItemTitle,
} from "@components/core/item";
import { Separator } from "@components/core/separator";

type Props = {
  collection: string;
  entries: CollectionEntry<keyof DataEntryMap>[];
  slug?: string;
  childFolders: string[];
  page: number;
  totalPages: number;
  baseUrl: string;
  baseLabel: string;
  indexEntry?: CollectionEntry<keyof DataEntryMap>;
};

const {
  collection,
  entries,
  slug,
  page,
  totalPages,
  baseUrl,
  baseLabel,
  indexEntry,
} = Astro.props;

const segments = slug ? slug.split("/") : [];
const lastSegment = segments.length > 0 ? segments.at(-1)! : undefined;
const title = lastSegment ? formatSegment(lastSegment) : baseLabel;
const rootUrl = `/${collection}/`;
const translateLabel = createTranslateLabel();
const titleLabels = lastSegment ? translateLabel(lastSegment) : undefined;
const baseLabels = Object.fromEntries(
  SUPPORTED_LOCALES.map((locale) => [
    locale,
    translations[locale]?.[collection] ?? baseLabel,
  ]),
);
---

<div class="grid gap-6">
  <div class="grid gap-2">
    <AstroRecursiveBreadcrumb
      baseUrl={rootUrl}
      baseLabels={baseLabels}
      slug={slug}
      translateLabel={translateLabel}
    />

    <h1
      class="text-3xl font-semibold tracking-tight"
      data-locales={titleLabels
        ? JSON.stringify(titleLabels)
        : JSON.stringify(baseLabels)}
    >
      {title}
    </h1>
  </div>

  {indexEntry && <AstroArticleImageViewer entry={indexEntry} />}

  <ul class="grid gap-4">
    {
      entries.map((entry) => (
        <li>
          <a href={`/${collection}/${entry.id}/`}>
            <Item
              variant="outline"
              className="hover:bg-muted transition-colors p-4"
            >
              <ItemContent>
                <div class="flex gap-2">
                  {entry.data.date && (
                    <>
                      <time
                        class="text-muted-foreground text-sm"
                        data-locales={JSON.stringify(
                          formatDateForLocales(entry.data.date),
                        )}
                      >
                        {formatDateForLocales(entry.data.date).en}
                      </time>
                      <Separator orientation="vertical" />
                    </>
                  )}
                  {entry.data.tags && (
                    <div class="flex gap-2">
                      <AstroTagBadges
                        tags={entry.data.tags}
                        translateLabel={translateLabel}
                        className="text-muted-foreground border-muted-foreground"
                      />
                    </div>
                  )}
                </div>
                <ItemTitle>{entry.data.title}</ItemTitle>
                {entry.data.description && (
                  <ItemDescription>{entry.data.description}</ItemDescription>
                )}
              </ItemContent>
            </Item>
          </a>
        </li>
      ))
    }
  </ul>

  <AstroPagination
    baseUrl={baseUrl}
    currentPage={page}
    totalPages={totalPages}
  />
</div>
