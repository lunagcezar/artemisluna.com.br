---
import { Button } from "@components/core/button";
import { t, translations, SUPPORTED_LOCALES } from "@i18n/labels";
import { SunIcon, MoonIcon } from "@phosphor-icons/react";

const lightLabels = JSON.stringify(
  Object.fromEntries(
    SUPPORTED_LOCALES.map((l) => [l, translations[l]?.light ?? "Light"]),
  ),
);
const darkLabels = JSON.stringify(
  Object.fromEntries(
    SUPPORTED_LOCALES.map((l) => [l, translations[l]?.dark ?? "Dark"]),
  ),
);
---

<div class="relative" data-theme-switcher>
  <Button variant="ghost" size="icon" aria-haspopup="menu" aria-expanded="false"
    ><SunIcon className="size-4 dark:hidden" />
    <MoonIcon className="hidden size-4 dark:block" /></Button
  >
  <div
    role="menu"
    class="bg-popover text-popover-foreground ring-border fixed z-50 hidden rounded-lg p-1 shadow-md ring-1"
  >
    <div class="flex flex-col">
      <Button
        role="menuitem"
        className="justify-start"
        variant="ghost"
        data-theme-option="light"
        data-locales={lightLabels}
        ><SunIcon className="size-4" />{t("light")}</Button
      >
      <Button
        role="menuitem"
        variant="ghost"
        className="justify-start"
        data-theme-option="dark"
        data-locales={darkLabels}
        ><MoonIcon className="size-4" />{t("dark")}</Button
      >
    </div>
  </div>
</div>

<script>
  import { initSelectMenus } from "@lib/dropdown";

  function setCookie(name: string, value: string): void {
    const expires = new Date(Date.now() + 365 * 864e5).toUTCString();
    document.cookie =
      name + "=" + value + "; expires=" + expires + "; path=/; SameSite=Lax";
  }

  const match = document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);
  const current =
    (match ? match[1] : null) ||
    (window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light");

  initSelectMenus({
    rootSelector: "[data-theme-switcher]",
    optionAttr: "data-theme-option",
    initialValue: current,
    onSelect(theme: string) {
      setCookie("theme", theme);
      document.documentElement.classList.toggle("dark", theme === "dark");
    },
  });
</script>
