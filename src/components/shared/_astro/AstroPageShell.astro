---
import { TooltipProvider } from "@components/core/tooltip";
import AstroNavbar from "./AstroNavbar.astro";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;
---

<TooltipProvider client:load>
  <AstroNavbar currentPath={currentPath} />
  <main class="mt-16"><slot /></main>
</TooltipProvider>
