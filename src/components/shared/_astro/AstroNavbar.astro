---
import { NAV_ITEMS } from "@constants/navigation";
import { getActiveSegment } from "@lib/url";
import { cn } from "@lib/utils";
import { ptLabels } from "@i18n/labels";
import LocaleSwitcher from "@components/shared/locale-switcher";
import ThemeSwitcher from "@components/shared/theme-switcher";

type Props = {
  currentPath: string;
  className?: string;
};

const { currentPath, className } = Astro.props;

const activeSegment = getActiveSegment(currentPath);

const items = NAV_ITEMS.map((item) => ({
  href: item.href,
  en: item.label,
  pt: ptLabels[item.href.replace("/", "")] ?? item.label,
}));
---

<nav
  class={cn(
    "fixed inset-x-0 mx-auto flex h-12 w-1/2 items-center justify-between gap-4 border-b",
    className,
  )}
>
  <a href="/" class="font-bold">Luna G. Cezar</a>
  <div class="flex gap-4">
    {
      items.map((item) => {
        const isActive = item.href.replace("/", "") === activeSegment;
        return (
          <a
            href={item.href}
            class={cn(isActive && "font-bold")}
            data-en={item.en}
            data-pt={item.pt}
          >
            {item.en}
          </a>
        );
      })
    }
  </div>
  <div class="flex items-center gap-1">
    <LocaleSwitcher client:load />
    <ThemeSwitcher client:load />
  </div>
</nav>

<script>
  (function () {
    var localeCookie = document.cookie.match(/(?:^|;\s*)locale=([^;]*)/);
    var locale = localeCookie ? localeCookie[1] : null;
    var isPt =
      locale === "pt" || (!locale && navigator.language.startsWith("pt"));
    if (isPt) {
      document.querySelectorAll("[data-pt]").forEach(function (el) {
        el.textContent = el.getAttribute("data-pt");
      });
    }

    var themeCookie = document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);
    var theme = themeCookie ? themeCookie[1] : null;
    var isDark =
      theme === "dark" ||
      (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches);
    if (isDark) {
      document.documentElement.classList.add("dark");
    }
  })();
</script>
