---
import { cn } from "@lib/utils";
import { buildFullSidebarTree } from "@lib/collections";
import { createSidebarHelpers } from "@lib/sidebar";
import AstroLocaleSwitcher from "./AstroLocaleSwitcher.astro";
import AstroThemeSwitcher from "./AstroThemeSwitcher.astro";
import AstroSidebarBranch from "./AstroSidebarBranch.astro";
import { XIcon, ListIcon } from "@phosphor-icons/react";
import { Button } from "@components/core/button";

type Props = {
  currentPath: string;
  className?: string;
};

const { currentPath, className } = Astro.props;

const { tree, collectionNames } = await buildFullSidebarTree();
const { getNodeLabels, nodeIsActive, nodeHasActiveDescendant } =
  createSidebarHelpers(currentPath, collectionNames);
---

<nav
  class={cn(
    "fixed inset-x-0 top-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm lg:w-3/4 xl:w-2/3 justify-self-center lg:border-x w-full",
    className,
  )}
>
  <div class="flex h-12 items-center justify-between px-4">
    <Button
      id="nav-toggle"
      aria-label="Toggle navigation"
      variant="ghost"
      size="icon"
      className="lg:hidden"
    >
      <ListIcon id="nav-icon-open" />
      <XIcon id="nav-icon-close" className="hidden" />
    </Button>

    <a href="/" class="font-semibold tracking-tight">Luna G. Cezar</a>

    <div class="flex items-center gap-1">
      <AstroLocaleSwitcher />
      <AstroThemeSwitcher />
    </div>
  </div>

  <div
    id="nav-drawer"
    class="border-border hidden max-h-[calc(100dvh-3rem)] overflow-y-auto border-y p-4"
  >
    <ul class="space-y-0.5">
      {
        tree.map((node) => (
          <AstroSidebarBranch
            node={node}
            getLabels={getNodeLabels}
            isActive={nodeIsActive}
            hasActiveDescendant={nodeHasActiveDescendant}
          />
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle");
  const drawer = document.getElementById("nav-drawer");
  const iconOpen = document.getElementById("nav-icon-open");
  const iconClose = document.getElementById("nav-icon-close");

  if (toggle && drawer) {
    toggle.addEventListener("click", () => {
      const isOpen = drawer.classList.toggle("hidden");
      iconOpen?.classList.toggle("hidden", !isOpen);
      iconClose?.classList.toggle("hidden", isOpen);
    });

    drawer.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        drawer.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
      });
    });
  }
</script>
