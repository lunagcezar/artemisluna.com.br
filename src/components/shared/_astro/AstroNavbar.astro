---
import { cn } from "@lib/utils";
import { buildFullSidebarTree } from "@lib/collections";
import { createSidebarHelpers } from "@lib/sidebar";
import AstroSiteBranch from "./AstroSiteBranch.astro";
import AstroSocialNetworks from "./AstroSocialNetworks.astro";
import { XIcon, ListIcon } from "@phosphor-icons/react";
import { Button } from "@components/core/button";
import { LocaleSwitcher } from "../locale-switcher";
import { ThemeSwitcher } from "../theme-switcher";
import { Search } from "../search";
import { Separator } from "@components/core/separator";

type Props = {
  currentPath: string;
  className?: string;
};

const { currentPath, className } = Astro.props;

const { tree, collectionNames } = await buildFullSidebarTree();
const { getNodeLabels, nodeIsActive, nodeHasActiveDescendant } =
  createSidebarHelpers(currentPath, collectionNames);
---

<nav
  class={cn(
    "fixed inset-x-0 top-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm lg:w-3/4 xl:w-2/3 2xl:w-4/7 justify-self-center lg:border-x w-full",
    className,
  )}
>
  <div class="flex h-12 items-center justify-between gap-2 px-4">
    <div class="flex items-center gap-2">
      <Button
        id="nav-toggle"
        aria-label="Toggle navigation"
        variant="ghost"
        size="icon"
        className="shrink-0 lg:hidden"
      >
        <ListIcon id="nav-icon-open" />
        <XIcon id="nav-icon-close" className="hidden" />
      </Button>
      <a href="/" class="text-primary shrink-0 text-xl font-bold tracking-tight"
        >Luna G. Cezar</a
      >
    </div>

    <div class="flex shrink-0 items-center gap-1">
      <Search client:load />
      <LocaleSwitcher client:visible />
      <ThemeSwitcher client:visible />
    </div>
  </div>

  <div
    id="nav-drawer"
    class="border-border hidden max-h-[calc(100dvh-3rem)] flex-col gap-2 overflow-y-auto border-y p-4"
  >
    <ul class="space-y-0.5">
      {
        tree.map((node) => (
          <AstroSiteBranch
            node={node}
            getLabels={getNodeLabels}
            isActive={nodeIsActive}
            hasActiveDescendant={nodeHasActiveDescendant}
          />
        ))
      }
    </ul>
    <Separator orientation="horizontal" />
    <AstroSocialNetworks className="pl-2" />
  </div>
</nav>

<script>
  const nav = document.querySelector("nav");
  const toggle = document.getElementById("nav-toggle");
  const drawer = document.getElementById("nav-drawer");
  const iconOpen = document.getElementById("nav-icon-open");
  const iconClose = document.getElementById("nav-icon-close");

  if (toggle && drawer) {
    const closeDrawer = () => {
      drawer.classList.remove("flex");
      drawer.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    };

    toggle.addEventListener("click", () => {
      const isOpen = drawer.classList.contains("hidden");
      drawer.classList.toggle("hidden", !isOpen);
      drawer.classList.toggle("flex", isOpen);
      iconOpen?.classList.toggle("hidden", isOpen);
      iconClose?.classList.toggle("hidden", !isOpen);
    });

    drawer.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });

    window.matchMedia("(min-width: 1024px)").addEventListener("change", (e) => {
      if (e.matches) closeDrawer();
    });

    document.addEventListener("click", (e) => {
      if (drawer.classList.contains("hidden")) return;
      if (nav?.contains(e.target as Node)) return;
      closeDrawer();
    });
  }
</script>
