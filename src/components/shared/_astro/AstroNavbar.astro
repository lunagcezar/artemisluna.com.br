---
import { getActiveSegment } from "@lib/url";
import { NAV_ITEMS } from "../../../constants/navigation";
import { cn } from "@lib/utils";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;

const activeSegment = getActiveSegment(currentPath);
---

<nav class="fixed flex h-12 w-full items-center justify-between gap-4 border-b">
  <a href="/" class="font-bold">Luna G. Cezar</a>
  <div class="flex gap-4">
    {
      NAV_ITEMS.map((item) => {
        const isActive = item.href.replace("/", "") === activeSegment;
        return (
          <a href={item.href} class={cn(isActive && "font-bold")}>
            {item.icon && <>{item.icon}</>}
            {item.label}
          </a>
        );
      })
    }
  </div>
</nav>
