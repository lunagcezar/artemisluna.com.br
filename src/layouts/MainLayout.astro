---
import AstroPageShell from "@components/shared/_astro/AstroPageShell.astro";
import "@styles/global.css";
import { getCanonicalUrl, getSiteRoot } from "@lib/url";
import { SOCIAL_LINKS, SAME_AS_URLS } from "@config/social";

export interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  author?: string;
  image?: string;
  lang?: string;
  titleLabels?: string;
  date?: string;
  type?: "website" | "article";
}

const {
  title,
  description,
  keywords,
  author,
  image,
  lang = "en",
  titleLabels,
  date,
  type = "website",
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = getCanonicalUrl(currentPath);
const siteRoot = getSiteRoot();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "Article" : "WebSite",
  headline: title ?? "Luna G. Cezar",
  description: description ?? "Art portfolio and wiki by Luna G. Cezar",
  url: canonicalUrl,
  ...(type === "article" && date && { datePublished: date }),
  ...(author && {
    author: { "@type": "Person", name: author, sameAs: SAME_AS_URLS },
  }),
  ...(image && {
    image: image.startsWith("http") ? image : `${siteRoot}${image}`,
  }),
  publisher: {
    "@type": "Person",
    name: "Luna G. Cezar",
    sameAs: SAME_AS_URLS,
  },
};
---

<html lang={lang}>
  <head>
    <script is:inline>
      (function () {
        var themeCookie = document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);
        var theme = themeCookie ? themeCookie[1] : null;
        var isDark =
          theme === "dark" ||
          (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches);
        if (isDark) {
          document.documentElement.classList.add("dark");
        }
        var localeMatch = document.cookie.match(/(?:^|;\s*)locale=([^;]*)/);
        var locale = localeMatch ? localeMatch[1] : "";
        if (locale) {
          document.documentElement.lang = locale;
        }
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {Object.values(SOCIAL_LINKS).map((url) => <link rel="me" href={url} />)}
    {description && <meta name="description" content={description} />}
    {author && <meta name="author" content={author} />}
    {
      keywords && keywords.length > 0 && (
        <meta name="keywords" content={keywords.join(", ")} />
      )
    }
    <title>{title ?? "Luna G. Cezar"}</title>
    {titleLabels && <meta name="page-title-labels" content={titleLabels} />}

    <meta property="og:title" content={title ?? "Luna G. Cezar"} />
    {description && <meta property="og:description" content={description} />}
    <meta
      property="og:type"
      content={type === "article" ? "article" : "website"}
    />
    <meta property="og:url" content={canonicalUrl} />
    {
      image && (
        <meta
          property="og:image"
          content={image.startsWith("http") ? image : `${siteRoot}${image}`}
        />
      )
    }
    {
      type === "article" && date && (
        <meta property="article:published_time" content={date} />
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? "Luna G. Cezar"} />
    {description && <meta name="twitter:description" content={description} />}
    {
      image && (
        <meta
          name="twitter:image"
          content={image.startsWith("http") ? image : `${siteRoot}${image}`}
        />
      )
    }

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body class="grid min-h-screen w-full">
    <AstroPageShell currentPath={currentPath}>
      <slot />
    </AstroPageShell>

    <script is:inline>
      (function () {
        var match = document.cookie.match(/(?:^|;\s*)locale=([^;]*)/);
        var locale =
          (match ? match[1] : "") || navigator.language.slice(0, 2) || "en";
        document.documentElement.lang = locale;
        document.querySelectorAll("[data-locales]").forEach(function (el) {
          try {
            var labels = JSON.parse(el.getAttribute("data-locales") || "{}");
            if (labels[locale]) el.textContent = labels[locale];
          } catch (_) {}
        });
        document.querySelectorAll("[data-locale-value]").forEach(function (el) {
          el.textContent = locale.toUpperCase();
        });
        document
          .querySelectorAll("[data-content-locale]")
          .forEach(function (el) {
            if (el.getAttribute("data-content-locale") !== locale) {
              el.setAttribute("hidden", "");
            }
          });
        var titleMeta = document.querySelector(
          'meta[name="page-title-labels"]',
        );
        if (titleMeta) {
          try {
            var titleLabels = JSON.parse(
              titleMeta.getAttribute("content") || "{}",
            );
            if (titleLabels[locale]) document.title = titleLabels[locale];
          } catch (_) {}
        }
      })();
    </script>
  </body>
</html>
