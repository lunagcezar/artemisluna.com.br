---
import AstroPageShell from "@components/shared/_astro/AstroPageShell.astro";
import "@styles/global.css";

export interface Props {
  title?: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title ?? "Artemis Luna"}</title>
  </head>
  <body class="grid min-h-screen w-full">
    <AstroPageShell currentPath={currentPath}>
      <slot />
    </AstroPageShell>
  </body>
</html>
