---
import AstroPageShell from "@components/shared/_astro/AstroPageShell.astro";
import "@styles/global.css";
import { getCanonicalUrl, getOgImageUrl } from "@lib/url";

export interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  author?: string;
  image?: string;
  lang?: string;
  titleLabels?: string;
}

const {
  title,
  description,
  keywords,
  author,
  image,
  lang = "en",
  titleLabels,
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = getCanonicalUrl(currentPath);
---

<html lang={lang}>
  <head>
    <script is:inline>
      (function () {
        var themeCookie = document.cookie.match(/(?:^|;\s*)theme=([^;]*)/);
        var theme = themeCookie ? themeCookie[1] : null;
        var isDark =
          theme === "dark" ||
          (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches);
        if (isDark) {
          document.documentElement.classList.add("dark");
        }
        var localeMatch = document.cookie.match(/(?:^|;\s*)locale=([^;]*)/);
        var locale = localeMatch ? localeMatch[1] : "";
        if (locale) {
          document.documentElement.lang = locale;
        }
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalUrl} />
    {description && <meta name="description" content={description} />}
    {author && <meta name="author" content={author} />}
    {
      keywords && keywords.length > 0 && (
        <meta name="keywords" content={keywords.join(", ")} />
      )
    }
    <title>{title ?? "Artemis Luna"}</title>
    {titleLabels && <meta name="page-title-labels" content={titleLabels} />}
    <meta property="og:title" content={title ?? "Artemis Luna"} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {image && <meta property="og:image" content={image} />}
  </head>
  <body class="grid min-h-screen w-full">
    <AstroPageShell currentPath={currentPath}>
      <slot />
    </AstroPageShell>

    <script is:inline>
      (function () {
        var match = document.cookie.match(/(?:^|;\s*)locale=([^;]*)/);
        var locale =
          (match ? match[1] : "") || navigator.language.slice(0, 2) || "en";
        document.documentElement.lang = locale;
        document.querySelectorAll("[data-locales]").forEach(function (el) {
          try {
            var labels = JSON.parse(el.getAttribute("data-locales") || "{}");
            if (labels[locale]) el.textContent = labels[locale];
          } catch (_) {}
        });
        document.querySelectorAll("[data-locale-value]").forEach(function (el) {
          el.textContent = locale.toUpperCase();
        });
        document
          .querySelectorAll("[data-content-locale]")
          .forEach(function (el) {
            if (el.getAttribute("data-content-locale") !== locale) {
              el.setAttribute("hidden", "");
            }
          });
        var titleMeta = document.querySelector(
          'meta[name="page-title-labels"]',
        );
        if (titleMeta) {
          try {
            var titleLabels = JSON.parse(
              titleMeta.getAttribute("content") || "{}",
            );
            if (titleLabels[locale]) document.title = titleLabels[locale];
          } catch (_) {}
        }
      })();
    </script>
  </body>
</html>
