---
import MainLayout from "@layouts/MainLayout.astro";
import type { ImageMetadata } from "astro";
import type { CollectionEntry } from "astro:content";
import AstroArticleImageViewer from "@components/shared/_astro/AstroArticleImageViewer.astro";
import AstroEntryList from "@components/core/_astro/AstroEntryList.astro";
import AstroArtCard from "@components/features/art/_astro/AstroArtCard.astro";
import { getCollection } from "astro:content";
import {
  SUPPORTED_LOCALES,
  createTranslateLabel,
  translations,
} from "@i18n/labels";
import { RECENT_PER_COLLECTION, RECENT_SECTIONS } from "@constants/collections";
import { resolveArtImage } from "@lib/art";
import type { RecentSectionData, CollectionName } from "../types/recent";

const pages = await getCollection("page");
const translateLabel = createTranslateLabel();

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/art/**/*.{jpg,jpeg,png,webp,gif}",
  { eager: true },
);

const recentData: RecentSectionData[] = await Promise.all(
  RECENT_SECTIONS.map(async ({ collection, display }) => {
    const all = await getCollection(collection as CollectionName);
    const entries = all
      .filter((e) => !("index" in e.data && e.data.index === true))
      .sort(
        (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0),
      )
      .slice(0, RECENT_PER_COLLECTION);

    const artCards =
      display === "art"
        ? (entries as CollectionEntry<"art">[]).map((entry) => {
            const firstImage = entry.data.images[0];
            return {
              entry,
              resolvedImage: firstImage
                ? resolveArtImage(firstImage.src, imageModules)
                : "",
            };
          })
        : undefined;

    return { collection, entries, artCards };
  }),
);
---

<MainLayout>
  <div class="grid gap-4">
    {
      SUPPORTED_LOCALES.map((locale) => {
        const page = pages.find((p) => p.data.lang === locale);
        return (
          page && (
            <div data-content-locale={locale}>
              <AstroArticleImageViewer entry={page} />
            </div>
          )
        );
      })
    }
    {
      recentData.some((d) => d.entries.length > 0) && (
        <div class="grid gap-12">
          {RECENT_SECTIONS.map(({ collection, display }) => {
            const data = recentData.find((d) => d.collection === collection);
            if (!data || data.entries.length === 0) return null;

            return (
              <section class="grid gap-4">
                <div class="flex items-center justify-between gap-3">
                  <h2
                    class="text-muted-foreground text-xs font-semibold tracking-widest uppercase"
                    data-locales={JSON.stringify(
                      Object.fromEntries(
                        SUPPORTED_LOCALES.map((l) => [
                          l,
                          `${translations[l]?.[collection] ?? collection} (${translations[l]?.latest ?? "Latest"})`,
                        ]),
                      ),
                    )}
                  >
                    {translations.en?.[collection] ?? collection} (Latest)
                  </h2>
                  <a
                    href={`/${collection}/`}
                    class="text-muted-foreground hover:text-foreground text-xs transition-colors"
                    data-locales={JSON.stringify(
                      Object.fromEntries(
                        SUPPORTED_LOCALES.map((l) => [
                          l,
                          translations[l]?.more ?? "More",
                        ]),
                      ),
                    )}
                  >
                    {translations.en?.more ?? "More"}
                  </a>
                </div>

                {display === "art" && data.artCards ? (
                  <div
                    aria-label="Recent artworks"
                    class="grid grid-cols-1 gap-2 sm:grid-cols-4"
                  >
                    {data.artCards.map(({ entry, resolvedImage }) => (
                      <AstroArtCard
                        entry={entry}
                        resolvedImage={resolvedImage}
                        translateLabel={translateLabel}
                      />
                    ))}
                  </div>
                ) : (
                  <AstroEntryList
                    collection={collection}
                    entries={data.entries}
                    translateLabel={translateLabel}
                  />
                )}
              </section>
            );
          })}
        </div>
      )
    }
  </div>
</MainLayout>
