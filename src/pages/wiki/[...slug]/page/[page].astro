---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import AstroRecursiveCollectionIndex from "@components/shared/_astro/AstroRecursiveCollectionIndex.astro";
import { getCollection } from "astro:content";
import {
  DEFAULT_PAGE_SIZE,
  filterEntriesByPrefix,
  getChildFolders,
  getDirectoryPaths,
  paginateEntries,
} from "@lib/collections";

type PaginationPath = {
  params: { slug: string | undefined; page: string };
  props: {
    slug: string | undefined;
    page: number;
    entries: CollectionEntry<"wiki">[];
  };
};

export const getStaticPaths = (async () => {
  const entries = await getCollection("wiki");
  const directoryPaths = [undefined, ...getDirectoryPaths(entries)];
  const paths: PaginationPath[] = [];

  for (const slug of directoryPaths) {
    const filtered = filterEntriesByPrefix(entries, slug);
    const totalPages = Math.max(
      1,
      Math.ceil(filtered.length / DEFAULT_PAGE_SIZE),
    );

    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { slug, page: String(page) },
        props: { slug, page, entries },
      });
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { slug, page, entries } = Astro.props;

const filtered = filterEntriesByPrefix(entries, slug);
const childFolders = getChildFolders(entries, slug);
const { pageEntries, totalPages, currentPage } = paginateEntries(
  filtered,
  page,
  DEFAULT_PAGE_SIZE,
);
const baseUrl = slug ? `/wiki/${slug}/` : "/wiki/";
---

<MainLayout>
  <div class="container mx-auto px-4 py-8">
    <AstroRecursiveCollectionIndex
      collection="wiki"
      entries={pageEntries}
      slug={slug}
      childFolders={childFolders}
      page={currentPage}
      totalPages={totalPages}
      baseUrl={baseUrl}
      baseLabel="Wiki"
    />
  </div>
</MainLayout>
