---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import CollectionIndex from '@components/CollectionIndex.astro';
import MainLayout from '@layouts/MainLayout.astro';
import { getSortedCollection } from '@lib/collections';

export const getStaticPaths = (async ({ paginate }) => {
  const entries = await getSortedCollection('wiki');
  return paginate(entries, { pageSize: 10 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props;
---

<MainLayout>
  <CollectionIndex collection="wiki" title="Wiki" page={page.currentPage} />
</MainLayout>
