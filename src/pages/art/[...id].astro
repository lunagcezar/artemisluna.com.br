---
import type { ImageMetadata } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import AstroEntryContent from "@components/core/_astro/AstroEntryContent.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("art");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: entry,
  }));
}

const entry = Astro.props;

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/art/**/*.{jpg,jpeg,png,webp,gif}",
  { eager: true },
);

function resolveImage(src: string) {
  if (!src.startsWith("/src/assets/art/")) return src;
  const mod = imageModules[src] as { default: ImageMetadata } | undefined;
  return mod ? mod.default : src;
}
---

<MainLayout title={entry.data.title}>
  <article>
    <h1>{entry.data.title}</h1>
    <p>
      {entry.data.type}
      {" · "}
      {entry.data.category}
      {" · "}
      {entry.data.medium}
      {
        entry.data.series && (
          <>
            {" · "}
            {entry.data.series}
          </>
        )
      }
    </p>
    {
      entry.data.tags.length > 0 && (
        <ul>
          {entry.data.tags.map((tag) => (
            <li>{tag}</li>
          ))}
        </ul>
      )
    }
    {
      entry.data.images?.map((img) => {
        const resolved = resolveImage(img.src);
        const src = typeof resolved === "string" ? resolved : resolved.src;
        return (
          <figure>
            <img src={src} alt={img.alt} />
            {img.caption && <figcaption>{img.caption}</figcaption>}
          </figure>
        );
      })
    }
    <AstroEntryContent entry={entry} />
  </article>
</MainLayout>
