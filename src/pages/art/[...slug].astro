---
import type { GetStaticPaths } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import AstroArtDetail from "@components/features/art/_astro/AstroArtDetail.astro";
import AstroArtGallery from "@components/features/art/_astro/AstroArtGallery.astro";
import {
  buildDirectoryIndex,
  getRecursiveEntries,
  getIndexAndDetailPaths,
  getPageTitleLabels,
  paginateEntries,
} from "@lib/collections";
import { DEFAULT_PAGE_SIZE } from "@constants/pagination";
import { createTranslateLabel } from "@i18n/labels";

export const getStaticPaths = (async () => {
  try {
    return await getIndexAndDetailPaths("art");
  } catch {
    return [];
  }
}) satisfies GetStaticPaths;

const { mode, entry, slug, entries } = Astro.props;
const translateLabel = createTranslateLabel("art");

const index = buildDirectoryIndex(entries ?? []);
const allEntries =
  mode === "index" ? getRecursiveEntries(slug ?? "", index) : [];
const { pageEntries, totalPages, currentPage } =
  mode === "index"
    ? paginateEntries(allEntries, 1, DEFAULT_PAGE_SIZE)
    : { pageEntries: [], totalPages: 1, currentPage: 1 };
const baseUrl = slug ? `/art/${slug}/` : "/art/";
const segments = slug ? slug.split("/") : [];
const lastSegment = segments.length > 0 ? segments.at(-1)! : undefined;
const pageTitleLabels = getPageTitleLabels(
  mode,
  lastSegment,
  "Art",
  translateLabel,
);
const pageTitle = mode === "detail" ? entry.data.title : pageTitleLabels.en;
const titleLabels = mode === "detail" ? undefined : pageTitleLabels.labelsJson;
---

<MainLayout
  title={pageTitle}
  titleLabels={titleLabels}
  description={mode === "detail" ? entry.data.description : undefined}
  keywords={mode === "detail" ? entry.data.tags : undefined}
  author={mode === "detail" ? entry.data.author : undefined}
  lang={mode === "detail" ? entry.data.lang : undefined}
>
  {
    mode === "detail" ? (
      <AstroArtDetail entry={entry} slug={slug} />
    ) : (
      <AstroArtGallery
        collection="art"
        entries={pageEntries}
        slug={slug}
        page={currentPage}
        totalPages={totalPages}
        baseUrl={baseUrl}
      />
    )
  }
</MainLayout>
