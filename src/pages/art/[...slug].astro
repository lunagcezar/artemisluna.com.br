---
import type { CollectionEntry } from "astro:content";
import MainLayout from "@layouts/MainLayout.astro";
import AstroArtDetail from "@components/features/art/_astro/AstroArtDetail.astro";
import AstroArtGallery from "@components/features/art/_astro/AstroArtGallery.astro";
import { getCollection } from "astro:content";
import {
  filterEntriesByPrefix,
  getChildFolders,
  getDirectoryPaths,
  paginateEntries,
} from "@lib/collections";
import { ART_PAGE_SIZE } from "@lib/art";

type DetailPath = {
  params: { slug: string };
  props: {
    mode: "detail";
    entry: CollectionEntry<"art">;
    entries: CollectionEntry<"art">[];
  };
};

type IndexPath = {
  params: { slug: string | undefined };
  props: {
    mode: "index";
    slug: string | undefined;
    entries: CollectionEntry<"art">[];
  };
};

export async function getStaticPaths() {
  const entries = await getCollection("art");
  const directoryPaths = getDirectoryPaths(entries);

  const detailPaths: DetailPath[] = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { mode: "detail", entry, entries },
  }));

  const indexPaths: IndexPath[] = [
    {
      params: { slug: undefined },
      props: { mode: "index", slug: undefined, entries },
    },
    ...directoryPaths.map((slug) => ({
      params: { slug },
      props: { mode: "index" as const, slug, entries },
    })),
  ];

  return [...detailPaths, ...indexPaths];
}

const { mode, entry, slug, entries } = Astro.props;
---

<MainLayout title={mode === "detail" ? entry.data.title : undefined}>
  <div class="container mx-auto px-4 py-8">
    {
      mode === "detail" ? (
        <AstroArtDetail entry={entry} />
      ) : (
        (() => {
          const filtered = filterEntriesByPrefix(entries, slug);
          const childFolders = getChildFolders(entries, slug);
          const { pageEntries, totalPages, currentPage } = paginateEntries(
            filtered,
            1,
            ART_PAGE_SIZE,
          );
          const baseUrl = slug ? `/art/${slug}/` : "/art/";

          return (
            <AstroArtGallery
              entries={pageEntries}
              slug={slug}
              childFolders={childFolders}
              page={currentPage}
              totalPages={totalPages}
              baseUrl={baseUrl}
            />
          );
        })()
      )
    }
  </div>
</MainLayout>
