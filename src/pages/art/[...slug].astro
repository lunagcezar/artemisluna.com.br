---
import type { GetStaticPaths } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import AstroArtDetail from "@components/features/art/_astro/AstroArtDetail.astro";
import AstroArtGallery from "@components/features/art/_astro/AstroArtGallery.astro";
import {
  buildDirectoryIndex,
  getRecursiveEntries,
  getIndexAndDetailPaths,
  paginateEntries,
} from "@lib/collections";
import { DEFAULT_PAGE_SIZE } from "@constants/pagination";
import { createTranslateLabel } from "@i18n/labels";

export const getStaticPaths = (async () => {
  return await getIndexAndDetailPaths("art");
}) satisfies GetStaticPaths;

const { mode, entry, slug, entries } = Astro.props;
const translateLabel = createTranslateLabel("art");

const index = buildDirectoryIndex(entries ?? []);
const dir = index[slug ?? ""];
const allEntries =
  mode === "index" ? getRecursiveEntries(slug ?? "", index) : [];
const childFolders = dir?.children ?? [];
const { pageEntries, totalPages, currentPage } =
  mode === "index"
    ? paginateEntries(allEntries, 1, DEFAULT_PAGE_SIZE)
    : { pageEntries: [], totalPages: 1, currentPage: 1 };
const baseUrl = slug ? `/art/${slug}/` : "/art/";
---

<MainLayout
  title={mode === "detail" ? entry.data.title : undefined}
  description={mode === "detail" ? entry.data.description : undefined}
  keywords={mode === "detail" ? entry.data.tags : undefined}
  author={mode === "detail" ? entry.data.author : undefined}
>
  {
    mode === "detail" ? (
      <AstroArtDetail entry={entry} translateLabel={translateLabel} />
    ) : (
      <AstroArtGallery
        collection="art"
        entries={pageEntries}
        slug={slug}
        childFolders={childFolders}
        page={currentPage}
        totalPages={totalPages}
        baseUrl={baseUrl}
      />
    )
  }
</MainLayout>
