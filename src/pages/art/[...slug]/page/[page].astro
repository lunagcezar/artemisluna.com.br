---
import type { GetStaticPaths } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import AstroArtGallery from "@components/features/art/_astro/AstroArtGallery.astro";
import {
  buildDirectoryIndex,
  getRecursiveEntries,
  getPaginationPaths,
  paginateEntries,
} from "@lib/collections";
import { DEFAULT_PAGE_SIZE } from "@constants/pagination";

export const getStaticPaths = (async () => {
  return await getPaginationPaths("art", DEFAULT_PAGE_SIZE);
}) satisfies GetStaticPaths;

const { slug, page, entries } = Astro.props;

const index = buildDirectoryIndex(entries);
const allEntries = getRecursiveEntries(slug ?? "", index);
const { pageEntries, totalPages, currentPage } = paginateEntries(
  allEntries,
  page,
  DEFAULT_PAGE_SIZE,
);
const baseUrl = slug ? `/art/${slug}/` : "/art/";
---

<MainLayout>
  <AstroArtGallery
    collection="art"
    entries={pageEntries}
    slug={slug}
    page={currentPage}
    totalPages={totalPages}
    baseUrl={baseUrl}
  />
</MainLayout>
