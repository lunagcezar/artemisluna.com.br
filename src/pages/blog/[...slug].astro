---
import type { GetStaticPaths } from "astro";
import MainLayout from "@layouts/MainLayout.astro";
import AstroRecursiveCollectionIndex from "@components/shared/_astro/AstroRecursiveCollectionIndex.astro";
import AstroEntryContent from "@components/core/_astro/AstroEntryContent.astro";
import {
  filterEntriesByPrefix,
  getChildFolders,
  getIndexAndDetailPaths,
  paginateEntries,
} from "@lib/collections";
import { DEFAULT_PAGE_SIZE } from "@constants/pagination";

export const getStaticPaths = (async () => {
  return await getIndexAndDetailPaths("blog");
}) satisfies GetStaticPaths;

const { mode, entry, slug, entries } = Astro.props;

const filtered = mode === "index" ? filterEntriesByPrefix(entries, slug) : [];
const childFolders = mode === "index" ? getChildFolders(entries, slug) : [];
const { pageEntries, totalPages, currentPage } =
  mode === "index"
    ? paginateEntries(filtered, 1, DEFAULT_PAGE_SIZE)
    : { pageEntries: [], totalPages: 1, currentPage: 1 };
const baseUrl = slug ? `/blog/${slug}/` : "/blog/";
---

<MainLayout
  title={mode === "detail" ? entry.data.title : "Blog"}
  description={mode === "detail" ? entry.data.description : undefined}
  keywords={mode === "detail" ? entry.data.tags : undefined}
  author={mode === "detail" ? entry.data.author : undefined}
>
  <div class="container mx-auto px-4 py-8">
    {
      mode === "detail" ? (
        <article class="grid gap-4">
          <h1 class="text-3xl font-semibold tracking-tight">
            {entry.data.title}
          </h1>
          <time class="text-muted-foreground text-sm">
            {entry.data.date.toLocaleDateString("pt-BR")}
          </time>
          <AstroEntryContent entry={entry} />
        </article>
      ) : (
        <AstroRecursiveCollectionIndex
          collection="blog"
          entries={pageEntries}
          slug={slug}
          childFolders={childFolders}
          page={currentPage}
          totalPages={totalPages}
          baseUrl={baseUrl}
          baseLabel="Blog"
        />
      )
    }
  </div>
</MainLayout>
