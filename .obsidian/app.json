{
  "userIgnoreFilters": [
    "node_modules",
    "dist",
    ".astro",
    ".wrangler",
    "public",
    ".vscode",
    ".husky",
    ".foam",
    ".git",
    ".gitignore",
    ".prettierrc",
    ".stignore",
    "AGENTS.md",
    "astro.config.mjs",
    "components.json",
    "docs",
    "eslint.config.ts",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "README.md",
    "tsconfig.json",
    "wrangler.jsonc",
    "src/components",
    "src/config",
    "src/constants",
    "src/hooks",
    "src/i18n",
    "src/layouts",
    "src/lib",
    "src/pages",
    "src/styles",
    "src/types",
    "src/content.config.ts"
  ],
  "attachmentFolderPath": "src/assets",
  "newFileLocation": "folder",
  "showUnsupportedFiles": true,
  "templateFolder": "_templates",
  "newFileFolderPath": "src/content",
  "propertiesInDocument": "source",
  "showLineNumber": false
}
