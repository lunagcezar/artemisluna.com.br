{
  "command_timeout": 5,
  "templates_folder": "_templates",
  "templates_pairs": [
    ["art", "_templates/art-entry.md"],
    ["blog", "_templates/blog-post.md"],
    ["wiki", "_templates/wiki-article.md"],
    ["writing", "_templates/writing-entry.md"]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    { "folder": "src/content/art", "template": "_templates/art-entry.md" },
    { "folder": "src/content/blog", "template": "_templates/blog-post.md" },
    { "folder": "src/content/wiki", "template": "_templates/wiki-article.md" },
    {
      "folder": "src/content/writing",
      "template": "_templates/writing-entry.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [],
  "startup_templates": [],
  "intellisense_render": 1,
  "ignore_folders_on_creation": [],
  "command_palette_timeout": 5000
}
