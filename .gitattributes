# Normalize all text files to LF in the repo
# On checkout, convert to native line endings (CRLF on Windows)
* text=auto

# Explicit text files
*.md text
*.ts text
*.mjs text
*.json text
*.yaml text
*.yml text
*.css text
*.astro text

# Binary files (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.svg binary
